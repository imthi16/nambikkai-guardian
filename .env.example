# Application
APP_ENV=development
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_DOCS_ENABLED=true
LOG_LEVEL=INFO
WEB_PORT=3000

# PostgreSQL / pgvector (local development values only)
POSTGRES_USER=nambikkai
POSTGRES_PASSWORD=nambikkai
POSTGRES_DB=nambikkai
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://nambikkai:nambikkai@localhost:5432/nambikkai

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# S3-compatible object storage (local MinIO values only)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=nambikkai-documents

# Authentication foundation. Replace with a secret-manager value before deployment.
JWT_SECRET=development-only-change-me

# Future provider configuration. Empty means no cloud provider is enabled.
LLM_PROVIDER=
LLM_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
