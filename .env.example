# Application
APP_ENV=development
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_DOCS_ENABLED=true
LOG_LEVEL=INFO
WEB_PORT=3000

# PostgreSQL / pgvector (local development values only)
POSTGRES_USER=attest
POSTGRES_PASSWORD=attest
POSTGRES_DB=attest
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://attest:attest@localhost:5432/attest

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# S3-compatible object storage (local MinIO values only)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=attest-documents

# Authentication. Replace JWT_SECRET with a secret-manager value before deployment.
JWT_SECRET=development-only-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Document uploads
MAX_UPLOAD_BYTES=26214400
DOWNLOAD_URL_TTL_SECONDS=300

# Ingestion pipeline
INGESTION_QUEUE_KEY=attest:ingestion:queue
INGESTION_DEAD_LETTER_KEY=attest:ingestion:dead
INGESTION_MAX_ATTEMPTS=3
INGESTION_STALE_AFTER_SECONDS=300
INGESTION_STORE_PAGE_IMAGES=true

# OCR: `tesseract` needs the system binary with tam+eng models;
# `paddle` needs the optional dependency group: `pip install -e '.[paddle]'`
OCR_ENGINE=none
OCR_LANGUAGES=tam+eng

# Chunking
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=150

# Embeddings (the MVP ships a local deterministic BGE-M3-compatible provider)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=bge-m3-local
EMBEDDING_MODEL_VERSION=hashing-v1
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_ATTEMPTS=3
EMBEDDING_BACKOFF_SECONDS=0.5

# Future provider configuration. Empty means no cloud provider is enabled.
LLM_PROVIDER=
LLM_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
