{
  "name": "nambikkai-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitest/coverage-v8": "3.2.7",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.2.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  }
}
